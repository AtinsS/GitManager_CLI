@echo off
chcp 65001 >nul
setlocal enabledelayedexpansion

:: –Я—А–Њ—Б—В—Л–µ —Ж–≤–µ—В–∞
set "GREEN=[92m"
set "YELLOW=[93m"
set "RED=[91m"
set "RESET=[0m"

:: –Я—Г—В–Є –Ї —Д–∞–є–ї–∞–Љ
set "SCRIPT_DIR=%~dp0"
set "RU_MAIN=%SCRIPT_DIR%ru\GIT-MANAGER-RU.bat"
set "EN_MAIN=%SCRIPT_DIR%en\GIT-MANAGER-EN.bat"

:: –Я—А–Њ–≤–µ—А–Ї–∞ Git
where git >nul 2>nul || (
    echo %YELLOW%Git not found! Please install Git for Windows: https://git-scm.com/%RESET%
    pause
    exit /b
)

:: –Р–≤—В–Њ–Њ–њ—А–µ–і–µ–ї–µ–љ–Є–µ —П–Ј—Л–Ї–∞
set "LANG=EN"

:: –°–њ–Њ—Б–Њ–± 1: –Я—А–Њ–≤–µ—А–Ї–∞ —З–µ—А–µ–Ј —А–µ–µ—Б—В—А (—П–Ј—Л–Ї –Є–љ—В–µ—А—Д–µ–є—Б–∞)
for /f "tokens=3" %%a in ('reg query "HKCU\Control Panel\Desktop" /v PreferredUILanguages 2^>nul') do (
    echo %%a | findstr /i "ru" >nul && set "LANG=RU"
)

:: –°–њ–Њ—Б–Њ–± 2: –Х—Б–ї–Є –љ–µ –љ–∞—И–ї–Є, –њ—А–Њ–±—Г–µ–Љ —З–µ—А–µ–Ј —Б–Є—Б—В–µ–Љ–љ—Г—О –ї–Њ–Ї–∞–ї—М
if "!LANG!"=="EN" (
    for /f "tokens=2 delims==" %%a in ('wmic os get OSLanguage /value 2^>nul') do set "OSLANG=%%a"
    if "!OSLANG!"=="1049" set "LANG=RU"
    if "!OSLANG!"=="25" set "LANG=RU"
)

:: –°–њ–Њ—Б–Њ–± 3: –Я—А–Њ–≤–µ—А–Ї–∞ —П–Ј—Л–Ї–Њ–≤–Њ–є —А–∞—Б–Ї–ї–∞–і–Ї–Є –Ї–ї–∞–≤–Є–∞—В—Г—А—Л
if "!LANG!"=="EN" (
    reg query "HKCU\Keyboard Layout\Preload" /s 2>nul | findstr /i "0419" >nul && set "LANG=RU"
)

:: –Ч–∞–њ—Г—Б–Ї –љ—Г–ґ–љ–Њ–є –≤–µ—А—Б–Є–Є
if "%LANG%"=="RU" (
    if exist "%RU_MAIN%" (
        call "%RU_MAIN%"
    ) else (
        echo %RED%–Ю—И–Є–±–Ї–∞: –љ–µ –љ–∞–є–і–µ–љ —Д–∞–є–ї %RU_MAIN%%RESET%
        pause
    )
) else (
    if exist "%EN_MAIN%" (
        call "%EN_MAIN%"
    ) else (
        echo %RED%Error: file not found %EN_MAIN%%RESET%
        pause
    )
)